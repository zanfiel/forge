{
  "name": "forge",
  "version": "0.1.0",
  "description": "AI code editor powered by Synapse",
  "main": "dist/main/main.js",
  "author": "Zan",
  "license": "Elastic-2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:svelte\" \"npm run dev:electron\"",
    "dev:svelte": "vite build --watch --mode development",
    "dev:electron": "wait-on dist/renderer/index.html && electron .",
    "build": "vite build && tsc -p tsconfig.main.json",
    "start": "electron .",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "monaco-editor": "^0.52.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "svelte": "^5.28.2",
    "svelte-check": "^4.2.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "dev.zanverse.forge",
    "productName": "Forge",
    "files": [
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
